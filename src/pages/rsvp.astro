---
import Layout from '../layouts/Layout.astro';

// ─────────────────────────────────────────────────────────────
// EVENT DETAILS — Erin: edit these values if anything changes.
// ─────────────────────────────────────────────────────────────
const event = {
  date: 'Saturday, September 26, 2026',
  time: '7:00 – 10:00 PM',
  venue: 'The Elmhurst Art Museum',
  address: '150 S Cottage Hill Ave, Elmhurst, IL 60126',
  rsvpBy: 'September 1, 2026',
  highlights: [
    'Open cocktail bar & hors d’oeuvres',
    'Live music',
    'Some words with Erin Dohan at 8:00 PM',
    'Cocktail attire',
  ],
};
---

<Layout
  title="RSVP — Book Launch Party for I Think I'm Ready to Talk"
  description="RSVP for the launch party celebrating Erin Dohan's debut memoir, I Think I'm Ready to Talk."
>

  <!-- Page header -->
  <section
    class="pt-36 pb-14 md:pt-44 md:pb-16"
    style="background-color: #FDF9F5; border-bottom: 1px solid #E8DED6;"
  >
    <div class="max-w-5xl mx-auto px-6">
      <p class="section-label">You're Invited</p>
      <h1 class="font-playfair text-5xl md:text-6xl font-bold text-dark mt-4 leading-tight max-w-2xl">
        Book Launch Party
      </h1>
      <p class="font-cormorant italic text-2xl mt-3 text-terracotta">
        Celebrating <em>I Think I'm Ready to Talk</em>
      </p>
      <p class="mt-5 max-w-lg text-mid leading-relaxed">
        Join Erin for an evening of celebration and community as she launches her debut memoir.
        Every RSVP is reviewed individually — once you submit the form below,
        you'll receive an email confirming your spot.
      </p>

      <!-- Event details -->
      <dl class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-2xl">
        <div>
          <dt class="font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-1">Date &amp; Time</dt>
          <dd class="font-playfair text-lg text-dark">{event.date}</dd>
          <dd class="font-playfair text-lg text-dark">{event.time}</dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-1">Location</dt>
          <dd class="font-playfair text-lg text-dark">{event.venue}</dd>
          <dd class="text-sm text-mid mt-1">{event.address}</dd>
        </div>
      </dl>

      <!-- What to expect -->
      <div class="mt-8 max-w-2xl">
        <p class="font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-3">What to Expect</p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2">
          {event.highlights.map(item => (
            <li class="flex gap-3 text-mid leading-relaxed">
              <span class="text-terracotta text-xs mt-1.5" aria-hidden="true">◈</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <p class="mt-8 font-cormorant italic text-xl text-terracotta">
        Kindly RSVP by {event.rsvpBy}.
      </p>
    </div>
  </section>


  <!-- RSVP form -->
  <section class="py-16 md:py-24" style="background-color: #FAF6F1;">
    <div class="max-w-2xl mx-auto px-6">

      <h2 class="font-playfair text-2xl font-bold text-dark mb-2">Request Your Spot</h2>
      <p class="text-sm text-mid mb-8 leading-relaxed">
        Submitting this form requests a spot rather than guaranteeing one — Erin will
        follow up by email to confirm your place. Fields marked
        <span class="text-terracotta">*</span> are required.
      </p>

      <!--
        Netlify Forms submission:
        - `netlify` enables Netlify's form handling on deploy
        - `netlify-honeypot` silently drops bot submissions that fill the hidden field
        - Netlify's built-in automatic spam filtering also runs on every submission
      -->
      <form
        name="rsvp"
        method="POST"
        action="/rsvp-confirmed"
        netlify
        netlify-honeypot="bot-field"
        class="space-y-6"
        aria-label="Book launch RSVP form"
      >
        <input type="hidden" name="form-name" value="rsvp" />
        <p style="display:none;">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="rsvp-name" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
              Name <span class="text-terracotta" aria-label="required">*</span>
            </label>
            <input
              id="rsvp-name"
              type="text"
              name="name"
              required
              autocomplete="name"
              class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200"
              style="background-color: #fff; border-color: #E8DED6;"
              placeholder="Your full name"
            />
          </div>

          <div>
            <label for="rsvp-email" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
              Email <span class="text-terracotta" aria-label="required">*</span>
            </label>
            <input
              id="rsvp-email"
              type="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200"
              style="background-color: #fff; border-color: #E8DED6;"
              placeholder="your@email.com"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="rsvp-attending" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
              Will you attend? <span class="text-terracotta" aria-label="required">*</span>
            </label>
            <select
              id="rsvp-attending"
              name="attending"
              required
              class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200"
              style="background-color: #fff; border-color: #E8DED6;"
            >
              <option value="">Select…</option>
              <option value="yes">Joyfully accepts</option>
              <option value="no">Regretfully declines</option>
              <option value="maybe">Not sure yet</option>
            </select>
          </div>

          <div>
            <label for="rsvp-guests" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
              Total in your party
            </label>
            <select
              id="rsvp-guests"
              name="party-size"
              class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200"
              style="background-color: #fff; border-color: #E8DED6;"
            >
              <option value="1">Just me</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5+">5 or more</option>
            </select>
          </div>
        </div>

        <div>
          <label for="rsvp-notes" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
            Leave a note for Erin (optional)
          </label>
          <textarea
            id="rsvp-notes"
            name="notes"
            rows="4"
            class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200 resize-y"
            style="background-color: #fff; border-color: #E8DED6;"
            placeholder="Accessibility needs, a message, or anything you'd like us to know…"
          ></textarea>
        </div>

        <div class="flex items-center justify-between flex-wrap gap-4 pt-2">
          <p class="text-xs text-light-mid">
            <span class="text-terracotta">*</span> Required fields
          </p>
          <button type="submit" class="btn btn-primary">
            Request My Spot
          </button>
        </div>
      </form>
    </div>
  </section>


  <!-- Walk the day after -->
  <section class="py-16 md:py-20" style="background-color: #FAF6F1; border-top: 1px solid #E8DED6;">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="section-label mb-4">The Morning After</p>
      <h2 class="font-playfair text-2xl md:text-3xl font-bold text-dark leading-tight">
        Walk with Erin's team
      </h2>
      <p class="mt-4 text-mid leading-relaxed">
        The day after the party — Sunday, September 27, 2026 — Erin is walking with
        the Brain Aneurysm Foundation, and she'd love for you to join her team.
        Come stretch your legs, meet fellow survivors and supporters, and keep the
        celebration going for a cause close to her heart.
      </p>

      <!-- Walk details -->
      <dl class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-2xl mx-auto text-left">
        <div>
          <dt class="font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-1">Date</dt>
          <dd class="font-playfair text-lg text-dark">Sunday, September 27, 2026</dd>
        </div>
        <div>
          <dt class="font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-1">Time</dt>
          <dd class="font-playfair text-lg text-dark">Registration 8:00 AM</dd>
          <dd class="text-sm text-mid mt-1">Walk begins 9:00 AM</dd>
        </div>
        <div>
          <dt class="font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-1">Location</dt>
          <dd class="font-playfair text-lg text-dark">McCormick Place</dd>
          <dd class="text-sm text-mid mt-1">Chicago, IL</dd>
        </div>
      </dl>

      <div class="mt-8 flex justify-center">
        <a
          href="https://give.bafound.org/site/TR/Events/General?pg=personal&px=1196233&fr_id=2910"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary w-full max-w-sm text-center"
        >
          Join the Walk Team
        </a>
      </div>
    </div>
  </section>


  <!-- Donate -->
  <section class="py-16 md:py-20" style="background-color: #FDF9F5; border-top: 1px solid #E8DED6;">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="section-label mb-4">Give Back</p>
      <h2 class="font-playfair text-2xl md:text-3xl font-bold text-dark leading-tight">
        Support brain aneurysm research
      </h2>
      <p class="mt-4 text-mid leading-relaxed">
        If you'd like to give in honor of the evening, Erin invites you to support
        two organizations close to her heart. Every gift helps fund research,
        awareness, and support for survivors and their families.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4">
        <a
          href="https://secure.qgiv.com/event/erindohansbooklaunch/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary w-full max-w-sm text-center"
        >
          Donate to The Bee Foundation
        </a>

        <a
          href="https://give.bafound.org/site/Donation2?PROXY_ID=1196233&5893.donation=form1&mfc_pref=T&idb=581904535&df_id=5893&PROXY_TYPE=20&FR_ID=2910"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline-terracotta w-full max-w-sm text-center"
        >
          Donate to the Brain Aneurysm Foundation
        </a>
      </div>
      <p class="mt-6 text-xs text-light-mid">
        Erin is a proud ambassador for The Bee Foundation.
      </p>
    </div>
  </section>


  <!-- Preorder the book -->
  <section class="py-16 md:py-20" style="background-color: #FDF9F5; border-top: 1px solid #E8DED6;">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="section-label mb-4">Before You Go</p>
      <h2 class="font-playfair text-2xl md:text-3xl font-bold text-dark leading-tight">
        Haven't reserved your copy yet?
      </h2>
      <p class="mt-4 text-mid leading-relaxed">
        <em class="font-cormorant not-italic">I Think I'm Ready to Talk</em> releases September 2026.
        Preorder now so it's waiting for you the moment it's out.
      </p>
      <div class="mt-8">
        <a href="/the-book/#preorder" class="btn btn-primary">
          Preorder the Book
        </a>
      </div>
    </div>
  </section>

</Layout>
