---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="RSVP Received — Erin Dohan"
  description="Thank you for your RSVP to the launch party for I Think I'm Ready to Talk."
>

  <section
    class="pt-36 pb-14 md:pt-44 md:pb-32"
    style="background-color: #FDF9F5; min-height: 60vh; display: flex; align-items: center;"
  >
    <div class="max-w-xl mx-auto px-6 text-center">
      <p class="section-label mb-6">Request Received</p>
      <h1 class="font-playfair text-4xl md:text-5xl font-bold text-dark leading-tight">
        Thank you — your request is in.
      </h1>
      <p class="mt-6 text-mid leading-relaxed">
        Each RSVP is reviewed individually. Erin will email you soon to confirm
        your spot, so please keep an eye on your inbox. If your plans change in
        the meantime, just reach out and let us know.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/the-book" class="btn btn-primary">About the Book</a>
        <a href="/" class="btn btn-secondary">Back to Home</a>
      </div>
    </div>
  </section>

</Layout>
