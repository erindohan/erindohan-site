---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout
  title="Blog — Erin Dohan"
  description="Erin Dohan writes about survival, healing, women's health, and the memoir process. Read the blog."
>

  <!-- Page header -->
  <section
    class="pt-36 pb-14 md:pt-44 md:pb-16"
    style="background-color: #FDF9F5; border-bottom: 1px solid #E8DED6;"
  >
    <div class="max-w-5xl mx-auto px-6">
      <p class="section-label">Blog</p>
      <h1 class="font-playfair text-5xl md:text-6xl font-bold text-dark mt-4 leading-tight">
        The Blog
      </h1>
      <p class="mt-5 max-w-xl text-mid leading-relaxed">
        On survival, healing, women's health, and the memoir process.
      </p>

    </div>
  </section>

  <!-- Posts grid -->
  <section class="py-16 md:py-24" style="background-color: #FAF6F1;">
    <div class="max-w-5xl mx-auto px-6">
      {sortedPosts.length === 0 ? (
        <p class="text-center text-light-mid py-20">No posts yet — check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sortedPosts.map((post, i) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              readTime={post.data.readTime}
              slug={post.slug}
              featured={i === 0}
              image={post.data.image}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Email band -->
  <section class="py-16 md:py-20" style="background-color: #2C2420;">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="font-playfair text-2xl md:text-3xl font-bold text-white leading-snug">
        New posts delivered to your inbox.
      </h2>
      <p class="mt-3 text-white/60 text-sm leading-relaxed">
        Join the list and get Erin's latest posts as soon as they're published.
      </p>
      <form
        action="#"
        data-kit-form
        class="mt-6 flex flex-col sm:flex-row gap-3 max-w-sm mx-auto"
        aria-label="Email signup form"
      >
        <label for="blog-email" class="sr-only">Email address</label>
        <input
          id="blog-email"
          type="email"
          name="email_address"
          required
          placeholder="your@email.com"
          autocomplete="email"
          class="flex-1 px-4 py-3 rounded-sm font-dm text-sm focus:outline-none focus:ring-2 focus:ring-terracotta-light"
          style="background-color: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.15);"
        />
        <button type="submit" class="btn btn-primary whitespace-nowrap">
          Subscribe
        </button>
      </form>
      <p class="kit-success" style="display:none; color: rgba(255,255,255,0.7); font-size: 0.9rem; margin-top: 1rem;">You're on the list — thank you!</p>
    </div>
  </section>

</Layout>
