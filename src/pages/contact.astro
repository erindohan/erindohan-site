---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Erin Dohan — Inquiries, Media & More"
  description="Get in touch with Erin Dohan for media inquiries, event bookings, speaking engagements, or just to say hello."
>

  <!-- Page header -->
  <section
    class="pt-36 pb-14 md:pt-44 md:pb-16"
    style="background-color: #FDF9F5; border-bottom: 1px solid #E8DED6;"
  >
    <div class="max-w-5xl mx-auto px-6">
      <p class="section-label">Get in Touch</p>
      <h1 class="font-playfair text-5xl md:text-6xl font-bold text-dark mt-4 leading-tight max-w-2xl">
        Let's start a conversation.
      </h1>
      <p class="mt-5 max-w-lg text-mid leading-relaxed">
        Please feel free to reach out about the book, brain aneurysm awareness, women's health, or simply to share your story.
        Erin would genuinely love to hear from you.
      </p>
      <div class="contact-hero-social">
        <a href="https://www.instagram.com/erindohanthings/" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          <span>@erindohanthings</span>
        </a>
        <a href="https://www.tiktok.com/@erindohanthings" target="_blank" rel="noopener" aria-label="TikTok" class="social-icon-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.78a4.85 4.85 0 0 1-1.01-.09z"/></svg>
          <span>@erindohanthings</span>
        </a>
        <a href="mailto:Erin@erindohan.com" class="social-icon-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/></svg>
          <span>Erin@erindohan.com</span>
        </a>
      </div>
    </div>
  </section>


  <!-- Contact content -->
  <section class="py-16 md:py-24" style="background-color: #FAF6F1;">
    <div class="max-w-5xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-3 gap-12 md:gap-16">

      <!-- Contact types sidebar -->
      <div class="lg:col-span-1">
        <h2 class="font-playfair text-xl font-bold text-dark mb-6">How can I help?</h2>
        <ul class="space-y-6">
          {[
            {
              label: 'Media & Press',
              description: 'Interview requests, review copies, author quotes, or press kit access.',
              icon: '◈',
            },
            {
              label: 'Speaking & Events',
              description: 'Book club visits, speaking engagements, panels, and workshops.',
              icon: '◈',
            },
            {
              label: 'Bookstores & Libraries',
              description: 'Stocking inquiries, readings, and community partnerships.',
              icon: '◈',
            },
            {
              label: 'Reader Notes',
              description: 'The most treasured kind. Erin reads every one.',
              icon: '◈',
            },
          ].map(item => (
            <li class="flex gap-4">
              <span class="text-terracotta text-xs mt-1.5" aria-hidden="true">{item.icon}</span>
              <div>
                <h3 class="font-dm font-semibold text-dark text-sm">{item.label}</h3>
                <p class="text-sm text-mid mt-1 leading-relaxed">{item.description}</p>
              </div>
            </li>
          ))}
        </ul>

      </div>


      <!-- Contact form -->
      <div class="lg:col-span-2">
        <!--
          To connect this form:
          - Netlify: add netlify attribute to <form> and netlify-honeypot="bot-field"
          - Formspree: set action="https://formspree.io/f/YOUR_ID"
          - Custom: set action to your API endpoint
        -->
        <form
          action="#"
          method="POST"
          class="space-y-6"
          aria-label="Contact form"
        >

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="contact-name" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
                Name <span class="text-terracotta" aria-label="required">*</span>
              </label>
              <input
                id="contact-name"
                type="text"
                name="name"
                required
                autocomplete="name"
                class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200"
                style="background-color: #fff; border-color: #E8DED6;"
                placeholder="Your full name"
              />
            </div>

            <div>
              <label for="contact-email" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
                Email <span class="text-terracotta" aria-label="required">*</span>
              </label>
              <input
                id="contact-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200"
                style="background-color: #fff; border-color: #E8DED6;"
                placeholder="your@email.com"
              />
            </div>
          </div>

          <div>
            <label for="contact-subject" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
              Subject
            </label>
            <select
              id="contact-subject"
              name="subject"
              class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200"
              style="background-color: #fff; border-color: #E8DED6;"
            >
              <option value="">Select a topic…</option>
              <option value="book">About the Book</option>
              <option value="aneurysm">Brain Aneurysm Awareness</option>
              <option value="womens-health">Women's Health Awareness</option>
              <option value="media">Media & Press Inquiry</option>
              <option value="speaking">Speaking or Events</option>
              <option value="story">Share Your Story</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="contact-message" class="block font-dm text-xs font-semibold uppercase tracking-widest text-light-mid mb-2">
              Message <span class="text-terracotta" aria-label="required">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="7"
              class="w-full px-4 py-3 rounded-sm font-dm text-sm text-dark border focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-all duration-200 resize-y"
              style="background-color: #fff; border-color: #E8DED6;"
              placeholder="Tell me what's on your mind…"
            ></textarea>
          </div>

          <div class="flex items-center justify-between flex-wrap gap-4">
            <p class="text-xs text-light-mid">
              <span class="text-terracotta">*</span> Required fields
            </p>
            <button type="submit" class="btn btn-primary">
              Send Message
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

</Layout>
