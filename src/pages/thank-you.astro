---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Message Received — Erin Dohan"
  description="Thank you for reaching out to Erin Dohan."
>

  <section
    class="pt-36 pb-14 md:pt-44 md:pb-32"
    style="background-color: #FDF9F5; min-height: 60vh; display: flex; align-items: center;"
  >
    <div class="max-w-xl mx-auto px-6 text-center">
      <p class="section-label mb-6">Message Received</p>
      <h1 class="font-playfair text-4xl md:text-5xl font-bold text-dark leading-tight">
        Thank you for reaching out.
      </h1>
      <p class="mt-6 text-mid leading-relaxed">
        Erin reads every message personally and will be in touch soon.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/blog" class="btn btn-secondary">Read the Blog</a>
      </div>
    </div>
  </section>

</Layout>
