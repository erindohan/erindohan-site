---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  readTime: string;
  slug: string;
  featured?: boolean;
}

const { title, description, pubDate, tags, readTime, slug, featured = false } = Astro.props;

const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const primaryTag = tags[0] ?? 'Essay';
---

{featured ? (
  <!-- Featured card — dark, large -->
  <article
    class="group relative flex flex-col justify-end p-8 md:p-10 rounded-sm overflow-hidden"
    style="background-color: #2C2420; min-height: 420px;"
  >
    <!-- Decorative accent -->
    <div
      class="absolute top-0 left-0 w-full h-1"
      style="background: linear-gradient(90deg, #C4836A, #E8798A);"
    ></div>

    <div class="relative z-10">
      <span class="section-label" style="color: #D9A08A;">{primaryTag}</span>
      <h3 class="mt-3 font-playfair text-2xl md:text-3xl font-bold leading-tight text-white group-hover:text-terracotta-light transition-colors duration-200">
        <a href={`/blog/${slug}`} class="after:absolute after:inset-0">
          {title}
        </a>
      </h3>
      <p class="mt-4 text-sm text-white/60 leading-relaxed line-clamp-3">
        {description}
      </p>
      <div class="mt-6 flex items-center gap-4 text-xs text-white/40">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        <span aria-hidden="true">·</span>
        <span>{readTime}</span>
      </div>
    </div>
  </article>
) : (
  <!-- Standard card — light -->
  <article
    class="group relative flex flex-col justify-between p-6 md:p-8 rounded-sm border"
    style="background-color: #FDF9F5; border-color: #E8DED6;"
  >
    <div>
      <span class="section-label">{primaryTag}</span>
      <h3 class="mt-3 font-playfair text-xl font-bold leading-snug text-dark group-hover:text-terracotta transition-colors duration-200">
        <a href={`/blog/${slug}`} class="after:absolute after:inset-0">
          {title}
        </a>
      </h3>
      <p class="mt-3 text-sm text-mid/80 leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>
    <div class="mt-6 flex items-center gap-4 text-xs text-light-mid">
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
      <span aria-hidden="true">·</span>
      <span>{readTime}</span>
    </div>
  </article>
)}
